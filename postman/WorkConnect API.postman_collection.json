          }
        },
        {
          "name": "Customer Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{customerToken}}"}
            ],
            "url": {
              "raw": "{{apiBaseUrl}}/customer/dashboard",
              "host": ["{{apiBaseUrl}}"],
              "path": ["customer", "dashboard"]
            }
          }
        }
      ]
    },
